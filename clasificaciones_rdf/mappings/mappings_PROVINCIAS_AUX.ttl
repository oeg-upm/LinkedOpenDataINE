
@prefix rr: <http://www.w3.org/ns/r2rml#>.
@prefix rml: <http://semweb.mmlab.be/ns/rml#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix xkos: <http://rdf-vocabulary.ddialliance.org/xkos#>.
@prefix dcat: <http://www.w3.org/ns/dcat#>.
@prefix ql: <http://semweb.mmlab.be/ns/ql#>.

<#ccaa-prov> a rr:TriplesMap;
    rml:logicalSource [
        rml:source "datasets/diccionario25.csv" ;
        rml:referenceFormulation ql:CSV
    ];
    rr:subjectMap [
        rr:template "http://lod.ine.es/kos/provincias/PROVINCIAS/1/{CPRO}";
    ];
    rr:predicateObjectMap [
        rr:predicate skos:broader ;
        rr:objectMap [ rr:template "http://lod.ine.es/kos/ccaa/CCAA/1/{CODAUTO}" ];
    ]. 
