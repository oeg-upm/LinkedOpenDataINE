@prefix rr: <http://www.w3.org/ns/r2rml#>.
@prefix rml: <http://semweb.mmlab.be/ns/rml#>.
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#>.
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#>.
@prefix xsd: <http://www.w3.org/2001/XMLSchema#>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#>.
@prefix foaf: <http://xmlns.com/foaf/0.1/>.
@prefix ql: <http://semweb.mmlab.be/ns/ql#>.
@prefix xkos: <http://rdf-vocabulary.ddialliance.org/xkos#>.
@prefix dcat: <http://www.w3.org/ns/dcat#>. 
@prefix place: <http://purl.org/ontology/places#>.
@prefix inelod: <https://lod.ine.es/cubes/vocabulary#>.

<#Level> a rr:TriplesMap;
    rml:logicalSource [
        rml:source "datasets/diccionario25.csv" ;
        rml:referenceFormulation ql:CSV
    ];    
    rr:subjectMap [
        rr:constant <http://lod.ine.es/kos/municipios/MUNICIPIOS/1>;
        rr:class xkos:ClassificationLevel;
    ];
    rr:predicateObjectMap [
        rr:predicate xkos:depth;
        rr:object 1 ;
    ];
    rr:predicateObjectMap [
        rr:predicate skos:inScheme;
        rr:object  <http://lod.ine.es/kos/municipios/MUNICIPIOS>;
    ];
    rr:predicateObjectMap [
        rr:predicate skos:member;
        rr:objectMap [rr:template "http://lod.ine.es/kos/ccaa/CCAA/1/{CPRO}{CMUN}"];
    ].

<#municipios> a rr:TriplesMap;
    rml:logicalSource [
        rml:source "datasets/diccionario25.csv" ;
        rml:referenceFormulation ql:CSV
    ];
    rr:subjectMap [
        rr:template "http://lod.ine.es/kos/municipios/MUNICIPIOS/1/{CPRO}{CMUN}";
        rr:class skos:Concept  ;
    ];
    rr:predicateObjectMap [
        rr:predicate skos:inScheme;
        rr:object <http://lod.ine.es/kos/municipios/MUNICIPIOS>;
    ];
    rr:predicateObjectMap [
        rr:predicate skos:notation ;
        rr:objectMap [ rr:template "{CPRO}{CMUN}";
                        rr:termType rr:Literal];
    ];
    rr:predicateObjectMap [
        rr:predicate skos:prefLabel ;
        rr:objectMap [ rr:template "{CPRO}{CMUN} {NOMBRE}";
                        rr:termType rr:Literal ;
                        rr:language "es"];
    ];
    rr:predicateObjectMap [
        rr:predicate skos:broader ;
        rr:objectMap [ 
            rr:template "http://lod.ine.es/kos/provincias/PROVINCIAS/1/{CPRO}"; ];
    ].
