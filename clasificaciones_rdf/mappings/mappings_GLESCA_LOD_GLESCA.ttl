@prefix rr: <http://www.w3.org/ns/r2rml#>.
@prefix rml: <http://semweb.mmlab.be/ns/rml#>.
@prefix ql: <http://www.w3.org/2004/ql#>.
@prefix skos: <http://www.w3.org/2004/02/skos/core#>.
@prefix xkos: <http://rdf-vocabulary.ddialliance.org/xkos#>.

<#LogicalSource> a rml:LogicalSource;
    rml:source "./datasets/Clasificaciones_GESCLA_LOD_CLASIFICACIONES.csv";
    rml:referenceFormulation ql:CSV.

<#ClassificationFamily> a rr:TriplesMap;
    rml:logicalSource <#LogicalSource>;
    rr:subjectMap [
        rr:template "http://lod.ine.es/clasificaciones/{Familia}";
        rr:class skos:Concept;
    ];
    rr:predicateObjectMap [
        rr:predicate skos:prefLabel;
        rr:objectMap [ rr:column "Familia clasificaciones" ];
    ].

<#Classification> a rr:TriplesMap;
    rml:logicalSource <#LogicalSource>;
    rr:subjectMap [
        rr:template "http://lod.ine.es/clasificaciones/{Familia}/{Clasificación}";
        rr:class skos:Concept;
    ];
    rr:predicateObjectMap [
        rr:predicate skos:prefLabel;
        rr:objectMap [ rr:column "Nombre" ]
    ];
    rr:predicateObjectMap [
        rr:predicate xkos:belongsTo;
        rr:objectMap [ rr:template "http://lod.ine.es/clasificaciones/{Familia}" ];
    ];
    rr:predicateObjectMap [
        rr:predicate xkos:follows;
        rr:objectMap [ rr:template "http://lod.ine.es/clasificaciones/{Familia}/{Sucede}" ];
    ].